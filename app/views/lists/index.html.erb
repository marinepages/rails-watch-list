<%= render "lists/banner",
  title: "Mes listes",
  subtitle: "Toutes vos listes de films triées selon vos critères.",
  image_url: "https://images.unsplash.com/photo-1524985069026-dd778a71c7b4?auto=format&fit=crop&w=1600&q=60",
  badge_text: pluralize(@lists.count, "list") %>

<div class="container my-4">

    <%= link_to "Create a list", new_list_path, class: "btn btn-primary" %>
</div>

  <div class="row g-3">
    <% @lists.each do |list| %>
      <div class="col-12 col-sm-6 col-lg-4">
        <%= link_to list_path(list), class: "text-decoration-none" do %>
          <div class="card h-100">

            <% if list.photo.attached? %>
              <%= cl_image_tag list.photo.key, height: 220, width: 360, crop: :fill, class: "card-img-top" %>
              <% else %>
            <img
              src="https://images.unsplash.com/photo-1489599849927-2ee91cede3ba?auto=format&fit=crop&w=1200&q=60"
              class="card-img-top"
              alt="cinema">
              <% end %>

            <div class="card-body">
              <h5 class="card-title text-dark"><%= list.name %></h5>
              <p class="card-text text-muted small mb-0">
                <%= pluralize(list.bookmarks.count, "movie") %>
              </p>
            </div>
          </div>
        <% end %>
      </div>
    <% end %>
  </div>
