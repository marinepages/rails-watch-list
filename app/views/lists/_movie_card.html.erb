<% movie = bookmark.movie %>

<div class="col-12 col-lg-6 mb-4">
  <div class="movie-card">
    <%= image_tag movie.poster_url, class: "movie-card-img" if movie.poster_url.present? %>

    <div class="movie-card-body">
      <h2 class="movie-card-title">
        <%= movie.title %>
        <span class="text-muted">• <%= movie.rating %></span>
        <i class="fa-solid fa-star text-warning"></i>
      </h2>

      <p class="movie-card-overview"><%= movie.overview %></p>

      <div class="movie-card-footer">
        <p class="mb-0">
          <i class="fa-solid fa-quote-left me-2"></i>
          <%= bookmark.comment %>
        </p>

        <%= link_to "delete",
          bookmark_path(bookmark),
          data: { turbo_method: :delete, turbo_confirm: "Are you sure?" },
          class: "movie-card-delete" %>
      </div>
    </div>
  </div>
</div>
