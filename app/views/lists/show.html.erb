  <% if @list.photo.attached? %>
  <% image_url = cl_image_path(@list.photo.key, width: 1600, height: 500, crop: :fill) %>
<% else %>
  <% image_url = asset_path("cinema.jpg") %>
<% end %>

<%= render "lists/banner",
  title: @list.name,
  subtitle: "Les films de ta liste #{@list.name}",
  image_url: image_url,
  badge_text: pluralize(@list.bookmarks.count, "movie") %>

<div class="container my-4">

  <div class="row">
    <% @list.bookmarks.each do |bookmark| %>
      <%= render "lists/movie_card", bookmark: bookmark %>
    <% end %>
  </div>

  <hr class="my-4">

  <%= simple_form_for([@list, @bookmark]) do |f| %>
    <%= f.association :movie %>
    <%= f.input :comment, placeholder: "Give your comment" %>
    <%= f.submit "Add to list", class: "btn btn-success" %>
  <% end %>

  <%= link_to "Back", lists_path, class: "btn btn-link mt-3" %>
</div>
